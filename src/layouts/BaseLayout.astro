---
import '../styles/global.css';
const { title, description, pathname = '/' } = Astro.props;
const site = 'https://northtexaspropertytransition.com';
const ogImage = new URL('/og-image.svg', site).toString();
const canonical = new URL(pathname, site).toString();
const nav = [
  { href: '/', label: 'Home' },
  { href: '/how-it-works', label: 'How It Works' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
      <!-- Analytics placeholder: add Google Analytics / Google tag when measurement ID is available. -->
    <!-- Search Console note: verify both the apex and redirect domains after final DNS cleanup. -->
</head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand">
          <span class="brand-name">North Texas Property Transition Services</span>
          <span class="brand-tagline">Inherited Home &amp; Senior Transition Specialists</span>
        </a>
        <nav class="nav" aria-label="Main navigation">
          {nav.map((item) => (
            <a href={item.href} aria-current={pathname === item.href ? 'page' : undefined}>{item.label}</a>
          ))}
          <a class="button primary" href="/contact">Schedule a Private Consultation</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <div>
          <div class="brand-name">North Texas Property Transition Services</div>
          <p class="footer-copy">Serving families across Dallas, Fort Worth, Plano, Frisco, McKinney, Allen, Arlington, Keller, Grand Prairie, Weatherford, and surrounding North Texas communities.</p>
        </div>
        <div class="footer-copy">Professional. Calm. Structured. Empathetic.</div>
      </div>
    </footer>
    <div class="mobile-cta-bar" aria-label="Quick consultation action">
      <a class="button primary" href="/contact">Schedule a Private Consultation</a>
    </div>
  </body>
</html>
