---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionIntro from '../components/SectionIntro.astro';
import CTASection from '../components/CTASection.astro';
---
<BaseLayout title="How Our Coordinated Property Transition Process Works | North Texas Property Transition Services" description="A clear, structured approach to selling a parent’s or inherited house — even when cleanout, repairs, or major decisions are involved." pathname="/how-it-works">
  <section>
    <div class="container">
      <SectionIntro eyebrow="How it works" title="How Our Coordinated Property Transition Process Works" subtitle="A clear, structured approach to selling a parent’s or inherited house — even when cleanout, repairs, or major decisions are involved." />
      <div class="steps">
        <div class="step-card"><h3>1. Private Consultation</h3><p>We start by understanding the family situation, property condition, timeline, and the transition decisions that matter most right now.</p></div>
        <div class="step-card"><h3>2. Cleanout &amp; Property Planning</h3><p>Cleanout, remediation, contents removal, and property strategy are coordinated together from the start — not treated as separate problems.</p></div>
        <div class="step-card"><h3>3. Smart Preparation</h3><p>We identify what truly needs to be handled before sale, what can wait, and what may not be necessary at all.</p></div>
        <div class="step-card"><h3>4. Sale &amp; Transition</h3><p>Once the right plan is clear, the property can move forward with more confidence, less friction, and fewer expensive surprises.</p></div>
      </div>
    </div>
  </section>
  <section>
    <div class="container split-grid">
      <div>
        <SectionIntro eyebrow="What makes this different" title="Coordinated from day one." subtitle="Instead of separately hiring a cleanout company, contractor, agent, and consultant, the process is aligned at the beginning." />
      </div>
      <div class="panel">
        <ul class="list">
          <li>Reduces stress and miscommunication</li>
          <li>Helps avoid duplicate effort and unnecessary expense</li>
          <li>Keeps the cleanout and sale strategy aligned</li>
          <li>Creates one structured path instead of several competing plans</li>
        </ul>
      </div>
    </div>
  </section>
  <CTASection title="Planning both the cleanout and the property strategy together changes the outcome." body="The earlier the full transition is coordinated, the easier it is to avoid wasted labor, unnecessary repair decisions, and last-minute confusion." />
</BaseLayout>
