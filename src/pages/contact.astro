---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionIntro from '../components/SectionIntro.astro';
---
<BaseLayout title="Schedule a Private Consultation | North Texas Property Transition Services" description="Request a private consultation for inherited home and senior transition property planning in North Texas." pathname="/contact">
  <section>
    <div class="container split-grid">
      <div>
        <SectionIntro eyebrow="Contact" title="Schedule a Private Consultation" subtitle="Tell us a little about the property and your situation. We will help you think through the cleanout and property transition plan clearly and privately." />
        <div class="panel">
          <ul class="list">
            <li>Inherited properties and probate situations</li>
            <li>Senior living and assisted living transitions</li>
            <li>Hoarding, deferred maintenance, and major cleanout concerns</li>
            <li>Out-of-state family coordination</li>
          </ul>
        </div>
      </div>
      <div class="contact-card">
        <form method="POST" action="https://formspree.io/f/placeholder">
          <div class="form-grid">
            <div class="field"><label for="name">Name</label><input id="name" name="name" autocomplete="name" required /></div>
            <div class="field"><label for="email">Email</label><input id="email" name="email" type="email" autocomplete="email" required /></div>
            <div class="field"><label for="phone">Phone</label><input id="phone" name="phone" type="tel" autocomplete="tel" /></div>
            <div class="field"><label for="city">Property City</label><input id="city" name="property_city" /></div>
          </div>
          <div class="field" style="margin-top:1rem;"><label for="message">Message</label><textarea id="message" name="message" placeholder="Tell us what kind of transition you are navigating and what concerns you most right now." required></textarea></div>
          <div class="button-row" style="margin-top:1rem;"><button class="button primary" type="submit">Schedule a Private Consultation</button></div>
          <p class="section-subtitle" style="margin-top:1rem;">Form submissions currently use a placeholder Formspree endpoint until a live consultation inbox is connected.</p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
